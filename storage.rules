rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /courseware/{userId}/{allPaths=**} {
      // Allow read access to authenticated students and lecturers
      allow read: if request.auth != null;
      
      // Allow write access only to the lecturer who owns the folder
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
