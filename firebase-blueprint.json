{
  "entities": {
    "material": {
      "title": "Course Material",
      "description": "Educational documents and resources uploaded by lecturers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseCode": { "type": "string", "description": "e.g., CSC 301" },
        "courseTitle": { "type": "string" },
        "lecturerName": { "type": "string" },
        "lecturerUid": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "level": { "type": "string", "enum": ["100L", "200L", "300L", "400L"] },
        "semester": { "type": "string", "enum": ["First", "Second"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "keyTopics": { "type": "array", "items": { "type": "string" }, "description": "3 key topics extracted from the material" },
        "overview": { "type": "string", "description": "A 2-line summary of the content" },
        "extractedText": { "type": "string", "description": "Full extracted text from the PDF for academic intelligence." }
      },
      "required": ["courseCode", "courseTitle", "lecturerName", "lecturerUid", "fileUrl", "level", "semester", "createdAt"]
    },
    "notice": {
      "title": "Bulletin Notice",
      "description": "Official notices posted by lecturers for specific student levels.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "targetLevel": { "type": "string", "enum": ["100L", "200L", "300L", "400L"] },
        "lecturerName": { "type": "string" },
        "lecturerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "targetLevel", "lecturerName", "lecturerUid", "createdAt"]
    },
    "user": {
      "title": "User Profile",
      "description": "User account information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "lecturer"] },
        "level": { "type": "string", "enum": ["100L", "200L", "300L", "400L"], "description": "Applicable for students" }
      },
      "required": ["uid", "email", "name", "role"]
    }
  },
  "firestore": {
    "/materials/{materialId}": {
      "schema": "material",
      "description": "Collection of course materials."
    },
    "/notices/{noticeId}": {
      "schema": "notice",
      "description": "Collection of official notices."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "User profile data."
    }
  }
}
